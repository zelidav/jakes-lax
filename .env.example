# === Jake's Lax — Integration Placeholders ===
# Copy to .env.local and fill in when you wire up real services.

# Shopify Storefront (for products + checkout)
NEXT_PUBLIC_SHOPIFY_DOMAIN=
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=

# Stripe (if using direct checkout instead of Shopify)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Supabase (auth + orders + customer data)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Klaviyo (email + SMS list capture)
KLAVIYO_PRIVATE_API_KEY=
NEXT_PUBLIC_KLAVIYO_LIST_ID=
NEXT_PUBLIC_KLAVIYO_SMS_LIST_ID=

# Instagram (Basic Display / Graph)
INSTAGRAM_ACCESS_TOKEN=
NEXT_PUBLIC_INSTAGRAM_HANDLE=jakeslax
